# ─── Google Sheets API ───────────────────────────────────────────────
# Used to store form submissions in a Google Sheet.
# See docs/setup-guide.md for step-by-step instructions.

GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ─── Mailtrap (Email) ───────────────────────────────────────────────
# Used to send email notifications on new submissions.
# Get your SMTP credentials at https://mailtrap.io → Email Testing → Inboxes → SMTP Settings

MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASS=

# ─── Email Configuration ────────────────────────────────────────────
# Where submission notifications are sent
NOTIFICATION_EMAIL=contact@funkyland.io

# The "from" address for notification emails
SENDER_EMAIL=noreply@funkyland.io
