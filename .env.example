# ─── Google Sheets API ───────────────────────────────────────────────
# Used to store form submissions in a Google Sheet.
# See docs/setup-guide.md for step-by-step instructions.
#
# IMPORTANT: Staging and Production use SEPARATE sheets.
#   Staging sheet:    "[STAGING] FEA Submissions"
#   Production sheet: "FEA Submissions"
# Each has its own SPREADSHEET_ID.

GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ─── Mailtrap (Email) ───────────────────────────────────────────────
# Staging uses Mailtrap SANDBOX (emails captured, not delivered):
#   MAILTRAP_HOST=sandbox.smtp.mailtrap.io
#   MAILTRAP_PORT=2525
#   MAILTRAP_USER=<sandbox username>
#   MAILTRAP_PASS=<sandbox password>
#
# Production uses Mailtrap SENDING (real email delivery):
#   MAILTRAP_HOST=live.smtp.mailtrap.io
#   MAILTRAP_PORT=587
#   MAILTRAP_USER=api
#   MAILTRAP_PASS=<your Mailtrap API token>

MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASS=

# ─── Email Configuration ────────────────────────────────────────────
# Where submission notifications are sent
NOTIFICATION_EMAIL=contact@funkyland.io

# The "from" address for notification emails
SENDER_EMAIL=noreply@funkyland.io
